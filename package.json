{
  "name": "tetromino-stacking",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "lint": "npm run lint:md && npm run lint:biome",
    "lint:md": "markdownlint \"**/*.md\" --ignore node_modules --ignore coverage",
    "lint:biome": "biome check .",
    "lint:shellcheck": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/run-shellcheck.ps1",
    "test": "vitest run --coverage",
    "test:guard": "vitest run --coverage --reporter=verbose",
    "verify:ci": "npm run test && npm run test:guard",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@vitest/coverage-v8": "^4.1.9",
    "glob": "^13.0.6",
    "jsdom": "^24.1.1",
    "markdownlint-cli": "^0.49.0",
    "vitest": "^4.1.9"
  }
}
